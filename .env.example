# =============================================================================
# TwitCanva Video Workflow — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值
# 所有路径除特别说明外均支持绝对路径和相对路径（相对项目根目录）
# =============================================================================

# ── Google Gemini ────────────────────────────────────────────────────────────
# 获取地址: https://aistudio.google.com/app/apikey
# 用途: Gemini 图片生成、Veo 视频生成
GEMINI_API_KEY=your_gemini_api_key_here

# ── Kling AI ────────────────────────────────────────────────────────────────
# 获取地址: https://app.klingai.com/global/dev/api-key
# 用途: Kling 图片和视频生成
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# ── Hailuo AI ──────────────────────────────────────────────────────────────
# 获取地址: https://platform.minimax.io/user-center/basic-information/interface-key
# 用途: Hailuo 视频生成
HAILUO_API_KEY=your_hailuo_api_key_here

# ── OpenAI ────────────────────────────────────────────────────────────────
# 获取地址: https://platform.openai.com/api-keys
# 用途: GPT Image 图片生成
OPENAI_API_KEY=your_openai_api_key_here

# ── Fal.ai ────────────────────────────────────────────────────────────────
# 获取地址: https://fal.ai/dashboard/keys
# 用途: Kling V2.6 Motion Control（通过 fal.ai 调用）
FAL_API_KEY=your_fal_api_key_here

# ── X (Twitter) 发帖功能 ──────────────────────────────────────────────────
# 获取地址: https://developer.twitter.com/en/portal
# 详细设置见 docs/post-to-x.md
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret
TWITTER_CALLBACK_URL=http://localhost:3001/api/twitter/callback

# ── TikTok 发帖功能 ─────────────────────────────────────────────────────────
# 获取地址: https://developers.tiktok.com/
# 详细设置见 docs/tiktok-integration.md
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app/api/tiktok-post/callback

# ── ComfyUI ───────────────────────────────────────────────────────────────
# ── 基础配置 ────────────────────────────────────────────────────────────────
# COMFYUI_BASE_URL: ComfyUI 服务地址（远程部署时填入实际 IP/域名）
COMFYUI_BASE_URL=http://127.0.0.1:8188

# COMFYUI_API_KEY: ComfyUI 的 API Key（如有）
COMFYUI_API_KEY=

# ── ComfyUI 参考图输入（本地目录模式）────────────────────────────────────────
# 此模式用于：ComfyUI 通过 LoadImage 直接读取本地文件路径
#
# 工作原理:
#   1. Backend 将参考图 base64 保存到 COMFYUI_INPUT_DIR
#   2. Preprocessor 向 ComfyUI 传入本地绝对路径（如 Z:\input\img_xxx.png）
#
# COMFYUI_INPUT_DIR: Backend/ComfyUI 共享的本地可写目录
#   Windows 示例: Z:/input
#   注意: 该目录必须能被 ComfyUI 进程访问
COMFYUI_INPUT_DIR=Z:/input

# ── ComfyUI 可选高级配置 ────────────────────────────────────────────────────
# 工作流执行超时时间（毫秒），默认 180000（3 分钟），LTX Video 建议 1800000（30 分钟）
COMFYUI_TIMEOUT_MS=1800000

# 轮询 ComfyUI 执行状态的间隔（毫秒），默认 3000（3 秒）
# COMFYUI_POLL_INTERVAL_MS=3000

# ── ComfyUI 自定义工作流 ID（旧版 ComfyUI-Manager 模式）──────────────────
# 如使用 ComfyUI-Manager 的 workflow_id 方式而非 JSON 文件方式，配置以下变量
# COMFY_WF_IMAGE_T2I=your_workflow_id_for_t2i
# COMFY_WF_IMAGE_I2I_SINGLE=your_workflow_id_for_i2i_single
# COMFY_WF_IMAGE_I2I_MULTI=your_workflow_id_for_i2i_multi
# COMFY_WF_VIDEO_STANDARD=your_workflow_id_for_video_standard
# COMFY_WF_VIDEO_FRAME2FRAME=your_workflow_id_for_video_frame2frame
